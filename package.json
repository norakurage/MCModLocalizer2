{
  "name": "mcmod-localizer2",
  "version": "1.0.0",
  "description": "Minecraft Mod 翻訳ツール (Electron 版)",
  "main": "./out/main/index.js",
  "homepage": "https://github.com/illbasashi/MCModLocalizer2",
  "author": "illbasashi",
  "license": "SEE LICENSE IN LICENSE.txt",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "adm-zip": "^0.5.16",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "keytar": "^7.9.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^2.0.0",
    "@electron-toolkit/eslint-config-ts": "^2.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron/rebuild": "^3.6.0",
    "@playwright/test": "^1.45.0",
    "@types/adm-zip": "^0.5.5",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^42.3.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.0",
    "postcss": "^8.4.41",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vitest": "^2.0.5"
  },
  "build": {
    "appId": "jp.illbasashi.mcmod-localizer",
    "productName": "MCModLocalizer",
    "copyright": "Copyright © 2025 illbasashi",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "!out/**/*.map"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources"
      }
    ],
    "win": {
      "target": "nsis",
      "arch": [
        "x64"
      ],
      "icon": "resources/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "arch": [
        "arm64",
        "x64"
      ],
      "icon": "resources/icon.icns"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    }
  },
  "engines": {
    "node": ">=20"
  }
}
